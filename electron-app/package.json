{
  "name": "dsc-agent-electron",
  "version": "0.1.0",
  "description": "Tray UI to control dsc-agent.js (non-destructive)",
  "main": "main.js",
  "private": true,
  "type": "commonjs",
  "author": {
    "name": "DSC Agent",
    "email": "support@example.com",
    "url": "https://example.com/dsc-agent"
  },
  "homepage": "https://example.com/dsc-agent",
  "icon": "assets/icon.png",
  "scripts": {
  "dev": "electron .",
  "electron": "electron .",
  "build": "electron-builder",
  "build:win": "electron-builder --win",
  "build:mac": "electron-builder --mac",
  "build:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^29.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.dscagent",
    "productName": "DSC Agent",
    "files": [
      "**/*"
    ],
    "extraResources": [
      {
        "from": "../agent",
        "to": "agent",
        "filter": ["**/*"]
      },
      {
        "from": "..",
        "to": "agent",
        "filter": [
          "dsc-agent.config.json",
          "package.json",
          "package-lock.json",
          "node_modules/**",
          "!electron-app/**",
          "!web-demo/**"
        ]
      },
      {
        "from": "../dsc-agent.config.json",
        "to": "dsc-agent.config.json"
      },
      {
        "from": "bin/win/",
        "to": "bin/win/",
        "filter": ["**/*"]
      },
      {
        "from": "bin/mac/",
        "to": "bin/mac/",
        "filter": ["**/*"]
      },
      {
        "from": "bin/linux/",
        "to": "bin/linux/",
        "filter": ["**/*"]
      }
    ],
    "win": {
      "icon": "assets/windows/icon.ico",
      "target": ["nsis", "portable"]
    },
    "mac": {
      "icon": "assets/mac/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "icon": "assets/icon.png",
      "target": ["AppImage", "deb", "rpm"],
      "maintainer": "DSC Agent <support@example.com>"
    }
  }
}
