{
  "name": "dsc-agent-electron",
  "version": "0.1.1",
  "description": "Tray UI to control dsc-agent.js (non-destructive)",
  "main": "main.js",
  "private": true,
  "type": "commonjs",
  "author": {
    "name": "DSC Agent",
    "email": "support@example.com",
    "url": "https://example.com/dsc-agent"
  },
  "homepage": "https://example.com/dsc-agent",
  "icon": "assets/icon.png",
  "scripts": {
    "dev": "electron .",
    "electron": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "@electron/fuses": "^2.1.1",
    "electron": "^29.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.example.dscagent",
    "productName": "DSC Agent",
    "afterPack": "scripts/apply-fuses.js",
    "files": [
      "**/*",
      "!build-artifacts/**",
      "!bin/**"
    ],
    "extraResources": [
      {
        "from": "../agent",
        "to": "agent",
        "filter": [
          "**/*",
          "!dsc-agent.js",
          "!dsc-agent_09_10.js",
          "!dsc-agent-all-working.js",
          "!dsc-agent - batch working.js",
          "!agen_backeup/**",
          "!lib/**",
          "!services/**"
        ]
      },
      {
        "from": "../build-artifacts/dsc-agent.obf.js",
        "to": "agent/dsc-agent.js"
      },
      {
        "from": "..",
        "to": "agent",
        "filter": [
          "dsc-agent.config.json"
        ]
      },
      {
        "from": "../node_modules/pkcs11js",
        "to": "agent/node_modules/pkcs11js",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../dsc-agent.config.json",
        "to": "dsc-agent.config.json"
      }
    ],
    "win": {
      "icon": "assets/windows/icon.ico",
      "extraResources": [
        {
          "from": "bin/win/",
          "to": "bin/win/",
          "filter": [
            "**/*"
          ]
        }
      ],
      "target": [
        "nsis",
        "portable"
      ]
    },
    "mac": {
      "icon": "assets/Mac/icon.png",
      "category": "public.app-category.business",
      "extraResources": [
        {
          "from": "bin/mac/",
          "to": "bin/mac/",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "linux": {
      "icon": "assets/linux/icon.png",
      "extraResources": [
        {
          "from": "bin/linux/",
          "to": "bin/linux/",
          "filter": [
            "**/*"
          ]
        }
      ],
      "target": [
        "AppImage",
        "deb",
        "rpm"
      ],
      "maintainer": "DSC Agent <support@example.com>"
    }
  }
}
